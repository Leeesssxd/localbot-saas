# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────
# Supabase / Railway PostgreSQL connection string.
# If your network is IPv4-only, prefer the Supabase session pooler:
# postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
# The app will add sslmode=require automatically if it is missing from the direct host.
DATABASE_URL=postgresql://postgres:REPLACE_WITH_DATABASE_PASSWORD@db.zopdjsdiawibnhlyoqvj.supabase.co:5432/postgres

# ─── JWT ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_RANDOM_64_BYTE_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_RANDOM_64_BYTE_HEX
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── AI Providers ─────────────────────────────────────────
AI_PROVIDER=groq
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_KEY
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_MS=10000

GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_KEY

# ─── Meta WhatsApp ─────────────────────────────────────────
META_WHATSAPP_API_URL=https://graph.facebook.com/v19.0

# ─── Frontend ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=info
